TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_GROUP_CHAT_ID=

# Scan all NSE EQ with last close ₹100–₹1000 (then F&O + strategy filters)
SCAN_UNIVERSE_MODE=nse_price_band
MIN_STOCK_PRICE=100
MAX_STOCK_PRICE=1500
SCAN_STRATEGIES=all
# all = Setup1+2 + EMA9/15 + EMA9/21 + EMA20+ST (Chaitu50c removed)
MIN_STRATEGIES_TO_CONFIRM=1
CHAITU_INTERVAL=15m
EMA_INTERVAL=15m
SEND_SCAN_SUMMARY=false
SEND_DAILY_SUMMARY=true
SEND_PREMARKET_MARKET_SUMMARY=true
SEND_SESSION_ALERTS=false
SEND_HEALTH_CHECK=false
SEND_BOOT_ALERT=false
MAX_SELL_ALERTS_PER_SCAN=1
NIFTY_OPTIONS_ENABLED=true
SENSEX_OPTIONS_ENABLED=true
SENSEX_STRIKE_STEP=100
EOD_SUMMARY_AFTER_HOUR=15
EOD_SUMMARY_AFTER_MINUTE=32
NIFTY_BTST_ENABLED=true
NIFTY_BTST_MIN_CONFIRM_PCT=80
STOCK_BTST_ENABLED=true
STOCK_BTST_MIN_CONFIRM_PCT=75
STOCK_BTST_MIN_GAIN_PCT=1.5
STOCK_BTST_MAX_ALERTS=3
STOCK_BTST_MIN_PRICE=50
STOCK_BTST_MAX_PRICE=1000
STOCK_BTST_SCREEN_TOP=50
STOCK_BTST_MIN_GAPUP_SCORE=4.0
# Global assets alerts (BTCUSD, ETHUSD, XAUUSD) in IST window
GLOBAL_ASSETS_ENABLED=true
GLOBAL_ALERT_START_HOUR=7
GLOBAL_ALERT_START_MINUTE=0
GLOBAL_ALERT_END_HOUR=23
GLOBAL_ALERT_END_MINUTE=0
GLOBAL_HTF_INTERVAL=4h
GLOBAL_ENTRY_INTERVAL=30m
GLOBAL_RR_RATIO=2
GLOBAL_FRACTAL_BARS=2
GLOBAL_ENGULF_ATR_MULT=0.35
GLOBAL_LONDON_START_HOUR=8
GLOBAL_LONDON_END_HOUR=16
GLOBAL_NY_START_HOUR=13
GLOBAL_NY_END_HOUR=22
GLOBAL_DEDUP_ENTRY_PCT=0.35
# Optional: richer BTST research summary when threshold is confirmed (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_STOCK_ENABLED=true
GEMINI_STOCK_SELECTION=true
GEMINI_STOCK_RANK=true
GEMINI_STOCK_ALERTS=true
# Groq fallback when Gemini quota/errors (https://console.groq.com/keys)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_FALLBACK_ENABLED=true
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama-3.3-70b
GH_MODELS_TOKEN=
GH_MODELS_MODEL=meta-llama/llama-3.3-70b-instruct
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
LLM_PROVIDER_ORDER=cerebras,openrouter,github_models,groq,gemini
SCAN_ALL_UNIVERSE_INTRADAY=false
YFINANCE_MIN_INTERVAL_SEC=0.45
YFINANCE_MAX_RETRIES=4
AI_SIGNAL_VALIDATE=false
AI_MIN_CONFIDENCE=5

# Upstox — generate Access Token in Apps → Analytics → Generate (API key/secret alone are not enough)
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_ACCESS_TOKEN=
UPSTOX_REDIRECT_URI=
# Trading token: app page Generate (NOT Analytics). Daily refresh via Telegram /upstox_token
UPSTOX_WS_ENABLED=true
UPSTOX_AUTO_TRADE_ENABLED=true
# Upstox places orders for Nifty/Sensex OPTIONS only (not stocks or BTST)
UPSTOX_PAPER_TRADE=false
TELEGRAM_COMMANDS_ENABLED=true
UPSTOX_DEFAULT_LOTS=1
UPSTOX_NIFTY_LOT_SIZE=65
UPSTOX_SENSEX_LOT_SIZE=20

# Option B — cron-job.org automation (scripts/setup_cron_job_org.ps1)
# API key: https://console.cron-job.org/settings
CRONJOB_API_KEY=

# GitHub classic PAT with repo scope: https://github.com/settings/tokens
GITHUB_PAT=
